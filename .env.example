# Voxa Platform Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/voxa_production

# OpenAI API Configuration (Required for AI analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Flask Security Configuration
SESSION_SECRET=your_secure_session_secret_here_make_it_long_and_random

# Email Configuration (Optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Admin Configuration
ADMIN_EMAILS=admin@rivvalue.com,admin@yourdomain.com

# Application Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Rate Limiting Configuration
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Database Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
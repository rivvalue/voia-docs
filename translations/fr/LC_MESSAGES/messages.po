msgid "Approaching client company limit. Only participants from existing companies can be added."
msgstr "Limite d'entreprises clientes atteinte. Seuls les participants des entreprises existantes peuvent être ajoutés."

#: participant_routes.py
#, python-format
msgid ""
"Cannot add participant: your license allows a maximum of %(max)d distinct "
"client companies (identified by email domain), and you already have "
"%(count)d. Participants from existing client companies can always be added."
msgstr ""
"Impossible d'ajouter le participant : votre licence autorise un maximum de "
"%(max)d entreprises clientes distinctes (identifiées par domaine d'e-mail), "
"et vous en avez déjà %(count)d. Les participants des entreprises clientes "
"existantes peuvent toujours être ajoutés."

#: participant_routes.py
#, python-format
msgid ""
"CSV upload rejected: adding these participants would exceed your client "
"company limit of %(max)d (currently at %(count)d). The following rows "
"introduce new client companies that would breach the limit:"
msgstr ""
"Importation CSV rejetée : l'ajout de ces participants dépasserait votre "
"limite d'entreprises clientes de %(max)d (actuellement à %(count)d). "
"Les lignes suivantes introduisent de nouvelles entreprises clientes qui "
"dépasseraient la limite :"

#: participant_routes.py
#, python-format
msgid "Row %(num)d: %(email)s (domain: %(domain)s)"
msgstr "Ligne %(num)d : %(email)s (domaine : %(domain)s)"

#: participant_routes.py
#, python-format
msgid "... and %(count)d more rows."
msgstr "... et %(count)d ligne(s) supplémentaire(s)."

#: participant_routes.py
#, python-format
msgid ""
"Note: Adding %(count)d participant(s) exceeds the %(license)s license "
"guideline of %(limit)d participants per campaign. Proceeding anyway."
msgstr ""
"Remarque : l'ajout de %(count)d participant(s) dépasse la recommandation "
"de la licence %(license)s de %(limit)d participants par campagne. "
"L'opération est tout de même effectuée."

#: participant_routes.py
msgid "Note: Participant count exceeds license guideline. Proceeding anyway."
msgstr "Remarque : le nombre de participants dépasse la recommandation de la licence. L'opération est tout de même effectuée."

#: business_auth_routes.py
msgid "Maximum client companies must be a positive number."
msgstr "Le nombre maximal d'entreprises clientes doit être un nombre positif."


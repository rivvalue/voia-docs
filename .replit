modules = ["python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["cairo", "cargo", "ffmpeg-full", "fontconfig", "freetype", "ghostscript", "glib", "gobject-introspection", "gtk3", "harfbuzz", "lcms2", "libev", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssh", "openssl", "pango", "pkg-config", "postgresql", "qhull", "rustc", "tcl", "tk", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
integrations = ["python_openai:1.0.0", "styling_replit:1.0.0", "python_database:1.0.0", "python_log_in_with_replit:1.0.0"]

[userenv]

[userenv.shared]
DETERMINISTIC_SURVEY_FLOW = "true"
PERF_MONITORING = "true"
ENABLE_WORKER_SCALING = "true"
GUNICORN_WORKERS = "4"
USE_ASYNC_WORKERS = "true"
OPTIMIZE_DB_POOL = "true"
USE_OPTIMIZED_QUERIES = "true"
ENABLE_EAGER_LOADING = "true"
ENABLE_COMPRESSION = "false"
FEATURE_SETTINGS_HUB_V2 = "true"
USE_REFACTORED_FRONTEND = "false"
USE_OPTIMIZED_DASHBOARD = "true"
ERROR_MONITORING_DEBUG = "true"

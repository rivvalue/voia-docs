modules = ["python-3.11", "postgresql-16", "python3"]

[nix]
channel = "stable-24_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 32823
externalPort = 3003

[[ports]]
localPort = 37827
externalPort = 8000

[[ports]]
localPort = 39939
externalPort = 6000

[[ports]]
localPort = 40739
externalPort = 3000

[[ports]]
localPort = 40957
externalPort = 6800

[[ports]]
localPort = 41175
externalPort = 3002

[[ports]]
localPort = 42097
externalPort = 3001

[[ports]]

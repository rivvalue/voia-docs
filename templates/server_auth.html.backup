{% extends 'base.html' %}

{% block title %}Authentication - VOÏA{% endblock %}

{% block content %}
<main class="auth-page-container" aria-labelledby="auth-main-heading">
    <div class="container-fluid">
        <!-- Header -->
        <header class="auth-hero text-center">
            <h1 id="auth-main-heading" class="auth-page-title">VO<span class="voia-red-accent">Ï</span>A - Turning voices into value</h1>
            <p class="auth-page-subtitle">
                Une expérience légère de Voice of Client alimentée par l'IA, conçue pour les petites et moyennes entreprises.
            </p>
            <div class="auth-info-alert" role="status">
                <small>
                    <div><i class="fas fa-clock me-1" aria-hidden="true"></i>Prend moins de 2 minutes
                    <i class="fas fa-users ms-3 me-1" aria-hidden="true"></i>Simulates a real customer or employee feedback flow</div>
                    <div class="mt-1"><i class="fas fa-chart-bar me-1" aria-hidden="true"></i>Inclut un tableau de bord d'analyse en direct juste après la fin
                    <i class="fas fa-shield-alt ms-3 me-1" aria-hidden="true"></i>Anonymous data collection</div>
                </small>
            </div>
        </header>

        <div class="row justify-content-center">
            <div class="col-xl-8">
                <article class="auth-main-card card">
                    <div class="auth-card-body card-body">
                        <!-- Server-side form submission -->
                        <form method="POST" action="{{ url_for('server_auth_generate') }}" aria-labelledby="form-heading">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}"/>
                            
                            <div class="auth-email-banner mb-4">
                                <h2 id="form-heading" class="auth-email-heading">Entrez une adresse e-mail pour générer un jeton de session sécurisé.</h2>
                                <small class="auth-email-subtext">No spam, no subscriptions. Just a hands-on look at how VOÏA works.</small>
                            </div>
                            
                            <div class="mb-4">
                                <label for="email" class="form-label auth-form-label">Adresse e-mail</label>
                                <small class="text-muted d-block mb-2">Used only to create a secure session. We won't contact you.</small>
                                <input type="email" 
                                       class="form-control auth-form-input" 
                                       id="email"
                                       name="email" 
                                       value="{{ request.form.get('email', '') }}" 
                                       placeholder="Entrez votre adresse e-mail" 
                                       required
                                       aria-required="true"
                                       aria-describedby="email-help">
                                <div id="email-help" class="visually-hidden">Saisissez votre e-mail pour générer un jeton de session sécurisé</div>
                            </div>
                            
                            <!-- Survey Type Selection -->
                            <div class="mb-4">
                                <label class="form-label auth-form-label">Choisissez votre expérience d'enquête</label>
                                <div class="row g-3 mt-2" role="group" aria-labelledby="survey-type-heading">
                                    <h3 id="survey-type-heading" class="visually-hidden">Options de type d'enquête</h3>
                                    
                                    <div class="col-md-6">
                                        <div class="survey-type-card card" 
                                             onclick="selectSurveyType('conversational', this)"
                                             role="button"
                                             tabindex="0"
                                             aria-pressed="false"
                                             onkeypress="if(event.key==='Enter'||event.key===' '){selectSurveyType('conversational', this)}">
                                            <div class="card-body">
                                                <div class="survey-type-icon conversational">
                                                    <i class="fas fa-comments" aria-hidden="true"></i>
                                                </div>
                                                <h4 class="survey-type-title">Interface conversationnelle</h4>
                                                <p class="survey-type-description">Interagissez avec notre système de traitement du langage naturel pour démontrer une collecte de données avancée basée sur le dialogue.</p>
                                                <span class="survey-type-badge recommended">
                                                    <i class="fas fa-star me-1" aria-hidden="true"></i>Recommended
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="survey-type-card card" 
                                             onclick="selectSurveyType('traditional', this)"
                                             role="button"
                                             tabindex="0"
                                             aria-pressed="false"
                                             onkeypress="if(event.key==='Enter'||event.key===' '){selectSurveyType('traditional', this)}">
                                            <div class="card-body">
                                                <div class="survey-type-icon traditional">
                                                    <i class="fas fa-list-alt" aria-hidden="true"></i>
                                                </div>
                                                <h4 class="survey-type-title">Questionnaire structuré</h4>
                                                <p class="survey-type-description">Méthodologie traditionnelle basée sur un formulaire pour une analyse comparative avec les approches conversationnelles.</p>
                                                <span class="survey-type-badge traditional">
                                                    <i class="fas fa-clipboard-check me-1" aria-hidden="true"></i>Traditional Method
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="d-grid">
                                <button type="submit" class="auth-submit-btn btn" aria-label="Générer un jeton d'authentification sécurisé">
                                    <i class="fas fa-key me-2" aria-hidden="true"></i>
                                    Generate Secure Token
                                </button>
                            </div>
                            
                            <div class="auth-privacy-notice">
                                <small>
                                    <i class="fas fa-shield-alt me-1" aria-hidden="true"></i>
                                    All data in this demo is anonymized. Read our privacy commitment for more info.
                                </small>
                            </div>
                        </form>
                        
                        <!-- Display results if available -->
                        {% if token_result %}
                        <div class="mt-4">
                            {% if token_result.success %}
                                <div class="auth-success-alert alert" role="alert">
                                    <h5><i class="fas fa-check-circle me-2" aria-hidden="true"></i>Jeton généré avec succès !</h5>
                                    <p><strong>Email:</strong> {{ token_result.email }}</p>
                                    <p><strong>Token:</strong> <code>{{ token_result.token }}</code></p>
                                    <p><strong>Expires in:</strong> {{ token_result.expires_in }} seconds</p>
                                    
                                    <div class="mt-3">
                                        <a href="{{ url_for('conversational_survey') }}?token={{ token_result.token }}" 
                                           id="dynamicSurveyButton"
                                           class="auth-survey-start-btn btn btn-lg"
                                           data-conversational-url="{{ url_for('conversational_survey') }}?token={{ token_result.token }}"
                                           data-traditional-url="{{ url_for('survey_form') }}?token={{ token_result.token }}"
                                           aria-label="Démarrer le type d'enquête sélectionné">
                                            <i class="fas fa-comments me-2" id="buttonIcon" aria-hidden="true"></i>
                                            <span id="buttonText">Démarrer l'enquête conversationnelle</span>
                                        </a>
                                    </div>
                                </div>
                            {% else %}
                                <div class="auth-error-alert alert" role="alert">
                                    <h5><i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i>Échec de la génération du jeton</h5>
                                    <p>{{ token_result.error }}</p>
                                </div>
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>
                </article>
            </div>
        </div>
    </div>
</main>

<script>
function selectSurveyType(type, cardElement) {
    // Remove selected class from all cards
    document.querySelectorAll('.survey-type-card').forEach(card => {
        card.classList.remove('selected');
        card.setAttribute('aria-pressed', 'false');
    });
    
    // Add selected class to clicked card
    cardElement.classList.add('selected');
    cardElement.setAttribute('aria-pressed', 'true');
    
    // Set the survey type in a hidden input
    let hiddenInput = document.getElementById('survey_type_input');
    if (!hiddenInput) {
        hiddenInput = document.createElement('input');
        hiddenInput.type = 'hidden';
        hiddenInput.name = 'survey_type';
        hiddenInput.id = 'survey_type_input';
        document.querySelector('form').appendChild(hiddenInput);
    }
    hiddenInput.value = type;
    
    // Update the survey button if token is already generated
    updateSurveyButton(type);
}

function updateSurveyButton(surveyType) {
    const button = document.getElementById('dynamicSurveyButton');
    const buttonText = document.getElementById('buttonText');
    const buttonIcon = document.getElementById('buttonIcon');
    
    if (button && buttonText && buttonIcon) {
        if (surveyType === 'conversational') {
            button.href = button.getAttribute('data-conversational-url');
            buttonIcon.className = 'fas fa-comments me-2';
            buttonText.textContent = 'Démarrer l'enquête conversationnelle';
        } else {
            button.href = button.getAttribute('data-traditional-url');
            buttonIcon.className = 'fas fa-list-alt me-2';
            buttonText.textContent = 'Start Traditional Survey';
        }
    }
}

// Initialize selection state on page load
document.addEventListener('DOMContentLoaded', function() {
    // Check if there was a previous selection from form data
    const previousSelection = '{{ request.form.get("survey_type", "conversational") }}';
    
    // Find the card for the previous selection
    const allCards = document.querySelectorAll('.survey-type-card');
    let selectedCard = null;
    
    allCards.forEach(card => {
        const onclickAttr = card.getAttribute('onclick');
        if (onclickAttr && onclickAttr.includes(previousSelection)) {
            selectedCard = card;
        }
    });
    
    if (selectedCard) {
        selectSurveyType(previousSelection, selectedCard);
    } else {
        // Fallback to conversational if no previous selection
        allCards.forEach(card => {
            const onclickAttr = card.getAttribute('onclick');
            if (onclickAttr && onclickAttr.includes('conversational')) {
                selectSurveyType('conversational', card);
            }
        });
    }
    
    // Initialize button text based on current selection
    updateSurveyButton(previousSelection);
});
</script>

{% endblock %}
